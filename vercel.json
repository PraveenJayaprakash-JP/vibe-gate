{
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/dashboard", "destination": "/web/dashboard/index.html" },
    { "source": "/:file(.+\\.(png|jpg|svg|ico))", "destination": "/public/:file" },
    { "source": "/(.*)", "destination": "/web/index.html" }
  ]
}
