{
  "name": "vibe-gate",
  "version": "0.1.0",
  "description": "Quality gate for AI-generated web apps. Scans for broken flows, security holes, and auth gaps.",
  "bin": {
    "vibe-gate": "./bin/vibe-gate.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node bin/vibe-gate.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vibe-coding",
    "ai-code",
    "quality-gate",
    "security",
    "testing"
  ],
  "license": "MIT",
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  }
}
